SECRET_KEY=dev-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=*
DATABASE_URL=postgres://postgres:postgres@localhost:5432/english_quiz
# The bot's FSM storage uses Redis DB 2, derived automatically from REDIS_URL.
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
TTS_PROVIDER=apps.common.tts.GTTSProvider
# Telegram bot token from @BotFather (required to run the bot process)
BOT_TOKEN=
# Bot run mode: polling (default) or webhook. Webhook needs a public https URL;
# the container listens on WEBHOOK_PORT behind your reverse proxy.
BOT_MODE=polling
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_PORT=8080
# Bot @username (no @) — enables the "add to group" deep link in the menu
BOT_USERNAME=
# Public https URL of the Mini App page (/webapp/). Set this to show the
# "🌐 Mini App" button in the bot menu. Telegram requires https (use a tunnel
# like ngrok/cloudflared locally, or your deployed domain).
WEBAPP_URL=
